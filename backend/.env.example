# SQLite (local dev, no Docker needed)
DATABASE_URL=sqlite:///./careerpilot.db

# PostgreSQL (production / Docker)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/careerpilot

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
GEMINI_API_KEY=your-gemini-api-key
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SECRET_KEY=your-secret-key-change-in-production

# Local dev without Firebase (disable in production)
DEV_MODE=true
DEV_AUTH_TOKEN=careerpilot-dev-local-token
